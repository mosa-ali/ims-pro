import { Toaster } from "@/components/ui/sonner";
import { TooltipProvider } from "@/components/ui/tooltip";
import NotFound from "@/pages/NotFound";
import { Route, Switch, Redirect } from "wouter";
import ErrorBoundary from "./components/ErrorBoundary";
import { ThemeProvider } from "./contexts/ThemeContext";
import { useState, useEffect } from "react";
import { checkBackendReady } from "./lib/health";
import { SystemStatusScreen, LoadingSpinner } from "./components/SystemStatusScreen";
import Home from "./pages/Home";
import Dashboard from "./pages/Dashboard";
import Organizations from "./pages/Organizations";
import OrganizationSettings from "./pages/OrganizationSettings";
import Invitations from "./pages/Invitations";
import InvitationAccept from "./pages/InvitationAccept";
import Grants from "./pages/Grants";
import GrantDetail from "./pages/GrantDetail";
import GrantNew from "./pages/GrantNew";
import GrantEdit from "./pages/GrantEdit";
import ActiveGrants from "./pages/ActiveGrants";
import Projects from "./pages/Projects";
import ProjectsDashboard from "./pages/ProjectsDashboard";
import ProjectDetail from "./pages/ProjectDetailNew";
import ProjectNew from "./pages/ProjectNew";
import ProjectEdit from "./pages/ProjectEdit";

import Finance from "./pages/Finance";
import MEAL from "./pages/MEAL";
import Surveys from "./pages/Surveys";
import SurveyBuilder from "./pages/SurveyBuilder";
import SurveyResponses from "./pages/SurveyResponses";
import Cases from "./pages/Cases";
import CaseDetail from "./pages/CaseDetail";
import Documents from "./pages/Documents";
import Settings from "./pages/Settings";
import LanguageSettings from "@/pages/LanguageSettings";
import UserManagement from "@/pages/UserManagement";
import RolesPermissions from "@/pages/RolesPermissions";
import OptionSets from "@/pages/OptionSets";
import EmailNotifications from "@/pages/EmailNotifications";
import LogoBranding from "@/pages/LogoBranding";
import SystemPublishSync from "@/pages/SystemPublishSync";
import AdministratorAccess from "@/pages/AdministratorAccess";
import SystemStatus from "./pages/SystemStatus";
import DeletedRecords from "./pages/DeletedRecords";
import ImportHistory from "./pages/ImportHistory";
import DemoLogin from "./pages/DemoLogin";

// Platform Administration
import PlatformLayout from "./components/PlatformLayout";
import PlatformDashboard from "./pages/platform/PlatformDashboard";
import PlatformOrganizations from "./pages/platform/PlatformOrganizations";
import PlatformOperatingUnits from "./pages/platform/PlatformOperatingUnits";
import PlatformUsers from "./pages/platform/PlatformUsers";
import PlatformSystemHealth from "./pages/platform/PlatformSystemHealth";
import PlatformAuditLogs from "./pages/platform/PlatformAuditLogs";
import PlatformSettings from "./pages/platform/PlatformSettings";

function Router() {
  return (
    <Switch>
      {/* Demo Login */}
      <Route path={"/demo-login"} component={DemoLogin} />
      
      <Route path={"/"} component={Home} />
      <Route path={"/dashboard"} component={Dashboard} />
      
      {/* Organization Management */}
      <Route path={"/organizations"} component={Organizations} />
      <Route path={"/organizations/:id/settings"} component={OrganizationSettings} />
      <Route path={"/organizations/:id/invitations"} component={Invitations} />
      
      {/* User Invitations */}
      <Route path={"/invitations/accept/:token"} component={InvitationAccept} />
      
      {/* Settings */}
      <Route path="/settings/language" component={LanguageSettings} />
      <Route path="/settings/users" component={UserManagement} />
      <Route path="/settings/roles" component={RolesPermissions} />
      <Route path="/settings/options" component={OptionSets} />
      <Route path="/settings/notifications" component={EmailNotifications} />
      <Route path="/settings/branding" component={LogoBranding} />
      <Route path="/settings/sync" component={SystemPublishSync} />
      <Route path="/settings/admin" component={AdministratorAccess} />      
      {/* Grant Management */}
      <Route path={"/grants/active"} component={ActiveGrants} />
      <Route path={"/grants/new"} component={GrantNew} />
      <Route path={"/grants/:id/edit"} component={GrantEdit} />
      <Route path={"/grants/:id"} component={GrantDetail} />
      <Route path={"/grants"}>
        {() => <Redirect to="/grants/active" />}
      </Route>
      
      {/* Project Management */}
      <Route path={"/projects"} component={ProjectsDashboard} />
      <Route path={"/projects/new"} component={ProjectNew} />
      <Route path={"/projects/list"} component={Projects} />
      <Route path={"/projects/:id/edit"} component={ProjectEdit} />
      <Route path={"/projects/:id"} component={ProjectDetail} />

      
      {/* Financial Management */}
      <Route path={"/finance"} component={Finance} />
      
      {/* MEAL Framework */}
      <Route path={"/meal"} component={MEAL} />
      
      {/* Survey & Data Collection */}
      <Route path={"/surveys"} component={Surveys} />
      <Route path={"/surveys/new"} component={SurveyBuilder} />
      <Route path={"/surveys/:id/edit"} component={SurveyBuilder} />
      <Route path={"/surveys/:id/responses"} component={SurveyResponses} />
      
      {/* Case Management */}
      <Route path={"/cases"} component={Cases} />
      <Route path={"/cases/:id"} component={CaseDetail} />
      
      {/* Document Management */}
      <Route path={"/documents"} component={Documents} />
      
      {/* Settings */}
      <Route path={"/settings"} component={Settings} />
      
      {/* Admin - System Status */}
      <Route path={"/admin/system-status"} component={SystemStatus} />
      
      {/* Admin - Deleted Records */}
      <Route path={"/admin/deleted-records"} component={DeletedRecords} />
      
      {/* Import History */}
      <Route path={"/import-history"} component={ImportHistory} />
      
      {/* Platform Administration */}
      <Route path="/platform/dashboard">
        {() => <PlatformLayout><PlatformDashboard /></PlatformLayout>}
      </Route>
      <Route path="/platform/organizations">
        {() => <PlatformLayout><PlatformOrganizations /></PlatformLayout>}
      </Route>
      <Route path="/platform/operating-units">
        {() => <PlatformLayout><PlatformOperatingUnits /></PlatformLayout>}
      </Route>
      <Route path="/platform/users">
        {() => <PlatformLayout><PlatformUsers /></PlatformLayout>}
      </Route>
      <Route path="/platform/system-health">
        {() => <PlatformLayout><PlatformSystemHealth /></PlatformLayout>}
      </Route>
      <Route path="/platform/audit-logs">
        {() => <PlatformLayout><PlatformAuditLogs /></PlatformLayout>}
      </Route>
      <Route path="/platform/settings">
        {() => <PlatformLayout><PlatformSettings /></PlatformLayout>}
      </Route>
      
      <Route path={"/404"} component={NotFound} />
      <Route component={NotFound} />
    </Switch>
  );
}

function App() {
  const [ready, setReady] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [retryCount, setRetryCount] = useState(0);

  useEffect(() => {
    const checkHealth = async () => {
      try {
        setError(null);
        await checkBackendReady();
        setReady(true);
      } catch (err) {
        console.error("Health check failed:", err);
        setError(
          err instanceof Error
            ? err.message
            : "System is initializing. Please wait."
        );
      }
    };

    checkHealth();
  }, [retryCount]);

  if (error) {
    return (
      <SystemStatusScreen
        title="System Initializing"
        message="Backend services are starting. Please refresh in a moment or click retry."
        showRetry={true}
        onRetry={() => setRetryCount((c) => c + 1)}
      />
    );
  }

  if (!ready) {
    return <LoadingSpinner message="Checking system readiness..." />;
  }

  return (
    <ErrorBoundary>
      <ThemeProvider defaultTheme="light">
        <TooltipProvider>
          <Toaster />
          <Router />
        </TooltipProvider>
      </ThemeProvider>
    </ErrorBoundary>
  );
}

export default App;
