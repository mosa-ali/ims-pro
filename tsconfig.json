{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*", "client/src/types/**/*", "docs/finance-new/AdvancedFinanceDashboard.tsx", "docs/finance-new/ExecutiveFinanceDashboard.tsx", "docs/finance-new/ProjectFinanceDetail.tsx", "docs/finance-new/ReportingCenter.tsx"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts", "src/imports/pasted_text"],
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    },
    "incremental": false,
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noErrorTruncation": false,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0"
  }
}
